{
  "manifest_version": 3,
  "name": "X-Media Downloader",
  "version": "2.0.0",
  "description": "X/Twitter Media Downloader with Side Panel support.",
  "permissions": [
    "storage",
    "downloads",
    "sidePanel"
  ],
  "web_accessible_resources": [
    {
      "resources": ["gallery.html", "downloadcenter.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://pbs.twimg.com/*",
    "*://video.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Open X-Media Side Panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
